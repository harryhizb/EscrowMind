# Frontend .env.example - Copy to frontend/.env and fill in your values

VITE_BACKEND_URL=http://localhost:3001

VITE_NETWORK=fuji
VITE_CHAIN_ID=43113
VITE_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Get WalletConnect Project ID from https://cloud.walletconnect.com/
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Contract addresses (auto-populated after deployment)
VITE_JOB_BOARD_ADDRESS=0x...
VITE_ESCROW_FACTORY_ADDRESS=0x...
VITE_REPUTATION_SBT_ADDRESS=0x...
VITE_CREDIT_MANAGER_ADDRESS=0x...

VITE_APP_NAME=EscrowMind
VITE_APP_VERSION=0.1.0
VITE_ENVIRONMENT=development

VITE_ENABLE_DEBUG_MODE=true
VITE_ENABLE_MOCK_CONTRACTS=false
