# Backend .env.example - Copy to backend/.env and fill in your values

PORT=3001
NODE_ENV=development

# Blockchain RPC
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Relayer private key - backend will use this to submit verification scores
RELAYER_PRIVATE_KEY=0x...your_relayer_private_key_here

# IPFS Pinata (optional - local cache used as fallback)
PINATA_API_KEY=your_pinata_api_key_optional
PINATA_SECRET_KEY=your_pinata_secret_key_optional

# Puppeteer & Verification
PUPPETEER_TIMEOUT=30000
VERIFICATION_PORT_RANGE_START=8000
VERIFICATION_PORT_RANGE_END=8100

LOG_LEVEL=debug
LOG_FILE=./logs/backend.log
