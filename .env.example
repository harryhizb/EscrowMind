# Root .env.example - Copy to .env and fill in your values

# ==========================================
# DEPLOYMENT & BLOCKCHAIN
# ==========================================
# Avalanche Fuji Testnet RPC endpoint
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Deployer wallet private key (who deploys contracts)
DEPLOYER_PRIVATE_KEY=0x...your_deployer_private_key_here

# Relayer wallet address (backend service wallet)
RELAYER_ADDRESS=0x...your_relayer_address_here
RELAYER_PRIVATE_KEY=0x...your_relayer_private_key_here

# Three arbiters for dispute resolution (2 of 3 vote required)
ARBITER_A=0x...arbiter_a_address
ARBITER_B=0x...arbiter_b_address
ARBITER_C=0x...arbiter_c_address

# Contract verification
SNOWTRACE_API_KEY=your_snowtrace_api_key_optional

# ==========================================
# HOW TO GET THESE VALUES
# ==========================================
# 1. Install MetaMask browser extension
# 2. Create new wallet or import existing
# 3. Add Avalanche Fuji network (https://docs.avax.network/quickstart/fuji-testnet)
# 4. Get testnet AVAX from faucet: https://faucet.avax.network/
# 5. Export private keys (Settings → Account Details → Export Private Key)
# 6. For SNOWTRACE_API_KEY: Register at https://snowtrace.io/apis and get free API key
